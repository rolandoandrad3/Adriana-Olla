---
import headerImg from "../../assets/img/headerImg.jpg";
---

<header
  class="relative h-screen bg-cover bg-center"
  style={{ backgroundImage: `url(https://res.cloudinary.com/dsri8v8hs/image/upload/v1772856932/aboutheader_k0lkl0.jpg)` }}
>
  <div class="absolute inset-0 bg-black/50"></div>
  <main
    class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
  >
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-6">Abogada y Notaria de la República de El Salvador</h1>
    <p class="text-lg md:text-2xl text-white mb-8 max-w-2xl">
      Confianza legal para salvadoreños dentro y fuera del país.
      </p>
    <a
      href="/contact"
      class="px-6 py-3 bg-[#0B2545] hover:bg-[#1D3A75] text-white font-semibold rounded-3xl transition"
    >
      Contáctanos
    </a>
  </main>
</header>
