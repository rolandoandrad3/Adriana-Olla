---
// src/pages/contact.astro (o donde tengas tu componente)
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="contact px-6 py-20 max-w-7xl mx-auto">
    <!-- Título centrado -->
    <h2 class="text-[#0B2545] text-3xl md:text-4xl font-extrabold text-center uppercase mb-12">
      Contáctenos
    </h2>

    <!-- Contenedor principal -->
    <div class="flex flex-col md:flex-row items-start gap-12">
      <!-- Texto -->
      <div class="w-full md:w-1/2 text-center md:text-left flex flex-col justify-center">
        <p class="text-gray-700 text-2xl font-bold leading-7 mb-6">
          Déjanos un mensaje y nos comunicaremos contigo pronto. Nuestro equipo está
          listo para brindarte asesoría personalizada y guiarte en cada paso
          del proceso.
        </p>
        <p class="text-gray-700 text-2xl font-bold leading-7">
          También puedes contactarnos directamente por teléfono o correo si lo prefieres.
        </p>
      </div>

      <!-- Formulario -->
      <div class="w-full md:w-1/2 bg-gray-50 rounded-2xl p-8">
        <form action="https://formsubmit.co/ale2004informacion1819@gmail.com" method="POST">
          <!-- Campos ocultos de FormSubmit -->
          <input type="hidden" name="_subject" value="Nuevo mensaje desde la web">
          <input type="hidden" name="_captcha" value="false">
          <input type="hidden" name="_template" value="table">

          <!-- Grid de dos columnas -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Nombre -->
            <div class="flex flex-col">
              <label for="nombre" class="font-semibold text-[#0B2545] mb-2">Nombre</label>
              <input type="text" id="nombre" name="nombre" placeholder="Tu nombre" class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]" required />
            </div>

            <!-- Apellido -->
            <div class="flex flex-col">
              <label for="apellido" class="font-semibold text-[#0B2545] mb-2">Apellido</label>
              <input type="text" id="apellido" name="apellido" placeholder="Tu apellido" class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]" required />
            </div>

            <!-- Correo -->
            <div class="flex flex-col">
              <label for="correo" class="font-semibold text-[#0B2545] mb-2">Correo</label>
              <input type="email" id="correo" name="correo" placeholder="you@example.com" class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]" required />
            </div>

            <!-- Teléfono -->
            <div class="flex flex-col">
              <label for="telefono" class="font-semibold text-[#0B2545] mb-2">Teléfono</label>
              <input type="tel" id="telefono" name="telefono" placeholder="+1 555-555-5555" class="border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-[#F9C74F]" />
            </div>
          </div>

          <!-- Mensaje -->
          <div class="flex flex-col mt-6">
            <label for="mensaje" class="font-semibold text-[#0B2545] mb-2">Mensaje</label>
            <textarea id="mensaje" name="mensaje" rows="5" placeholder="Escribe tu consulta aquí..." class="border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-[#F9C74F] resize-none" required></textarea>
          </div>

          <!-- Botón de WhatsApp -->
          <div class="text-center md:text-right mt-4">
            <a
              href="https://wa.me/50361920844?text=Hola,%20quiero%20agendar%20una%20consulta%20legal"
              target="_blank"
              class="inline-block rounded-lg border border-[#0B2545] px-7 py-3 font-medium text-[#0B2545] hover:bg-gray-50 transition"
            >
              Enviar
            </a>
          </div>
        </form>
      </div>
    </div>
  </section>
</Layout>